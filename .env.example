# Base API URL (no trailing slash recommended)
VITE_API_BASE_URL=https://fisdemoprojects.com/assanhisaab

# Optional: refresh endpoint path (relative to base URL)
# Example: /refresh.php
VITE_API_REFRESH_PATH=

# Optional: CORS proxy (use ONE of the following)
# 1) Simple prefix where proxy expects the full target URL appended
# Example: https://my-proxy.example
VITE_CORS_PROXY_URL=

# 2) Template for proxies that require query params
# Available placeholders: {{url}} and {{encodedUrl}}
# Example: https://my-proxy.example/?url={{encodedUrl}}
VITE_CORS_PROXY_TEMPLATE=

# Optional: where to send users after auto-logout
VITE_AUTH_LOGOUT_REDIRECT=/login

